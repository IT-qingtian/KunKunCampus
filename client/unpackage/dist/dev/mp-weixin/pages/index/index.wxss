.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.content .swiper {
  background-color: pink;
  width: 750rpx;
}
.content .swiper swiper-item image {
  width: 750rpx;
  height: 100%;
}
.content .function {
  background-color: hotpink;
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-evenly;
}
.content .function .fun_item {
  padding: 5px 50rpx;
  text-align: center;
}
.content .function .fun_item ._i {
  font-size: 100rpx;
}

