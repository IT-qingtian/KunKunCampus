.main {
  margin-top: 15px;
  width: 90%;
  left: 50%;
  -webkit-transform: translateX(-50%);
          transform: translateX(-50%);
  position: absolute;
  box-sizing: border-box;
}
.main .type {
  display: flex;
  justify-content: space-around;
}
.main .type text {
  color: #a9a6a7;
}
.main .type .active {
  padding-bottom: 5px;
  border-bottom: 5px solid #e9ea60;
  color: black;
  font-weight: bold;
}
.main .md {
  overflow: hidden;
}
.main .md .mode {
  transition: all 0.5s;
  position: relative;
}
.main .md .mode .type_2 {
  width: 100%;
  -webkit-transform: translateX(100%);
          transform: translateX(100%);
  background-color: red;
  position: absolute;
  top: 0;
}
.main .md .mode_1 {
  -webkit-transform: translateX(0);
          transform: translateX(0);
}
.main .md .mode_2 {
  -webkit-transform: translateX(-100%);
          transform: translateX(-100%);
}
.card {
  box-sizing: border-box;
  box-shadow: 0 3px 10px 1px rgba(0, 0, 0, 0.5);
  padding: 5px;
  margin-bottom: 7px;
  border-radius: 5px;
  background-color: #f7f7f7;
}
.card .card_item {
  border-top: 1px solid #726c6c;
  display: flex;
  padding: 5px;
  justify-content: space-between;
}
.card .card_item .left {
  font-weight: bold;
}
.card .card_item .right {
  font-size: 12px;
  color: #8f8f94;
}
.card .pay .left {
  flex: 7;
}
.card .pay .right {
  background-color: #fdc938;
  text-align: center;
  color: black;
  font-size: 15px;
  border-radius: 6px;
  flex: 3;
}
.card .card_item:first-child {
  border: none;
}
.pay {
  padding: 0;
}
.bg .t {
  width: 750rpx;
  height: 130px;
  border-bottom-left-radius: 10%;
  border-bottom-right-radius: 10%;
  background-color: #fdc938;
}

